        $sd  = ($_POST["sd"]);

   $query = $db->prepare("UPDATE levels SET starDemon = $sd, starAuto = $sa, starFeatured = $rfe, starStars = $stars, starDifficulty = $difficulty WHERE levels.levelID = $levelID");
	$query->execute();
   echo "Level rated!";
}else{
